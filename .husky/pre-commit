#!/bin/sh
set -e

# ── Terraform validate ────────────────────────────────────────────────────────
if [ -d "iac/.terraform" ]; then
  echo "▶ terraform validate"
  (cd iac && terraform validate)
else
  echo "⚠  terraform validate skipped — run 'terraform init' in iac/ first"
fi

# ── Rust type check ───────────────────────────────────────────────────────────
echo "▶ cargo check"
(cd api && cargo check 2>&1)

# ── TypeScript type check ─────────────────────────────────────────────────────
if [ -f "web/node_modules/.bin/tsc" ]; then
  echo "▶ tsc"
  (cd web && ./node_modules/.bin/tsc --noEmit 2>&1)
else
  echo "⚠  tsc skipped — run 'npm install' in web/ first"
fi
